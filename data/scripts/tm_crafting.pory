// TM crafting machine. Opens the full-screen crafting menu (src/tm_crafting_menu.c).
// See include/config/tm_crafting.h (TM_CRAFTING) and src/data/tm_crafting.h (recipes).
//
// To use: point an object event's script at TMCrafting_EventScript_Machine (in
// Porymap), or `call(TMCrafting_EventScript_Machine)` from any other script.

script TMCrafting_EventScript_Machine {
    lock
    faceplayer
    callnative(TMCrafting_OpenMenu)
    waitstate
    release
    end
}
